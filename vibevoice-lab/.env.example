# ============================================================================
#  .env template for the VibeVoice lab stack.
#  Copy: cp .env.example .env
# ============================================================================

## Stack identity
COMPOSE_PROJECT_NAME=vibevoice_lab

## Path to the upstream VibeVoice checkout. Default: `VibeVoice/` subfolder
## next to this compose file (populated by setup_lab.sh).
VIBEVOICE_SRC=./VibeVoice

## Base image. x86 NVIDIA: nvcr.io/nvidia/pytorch:25.09-py3 (CUDA 12.x).
## GB10 DGX Spark (aarch64, CUDA 13): nvcr.io/nvidia/pytorch:25.12-py3
## plus TORCH_CUDA_ARCH_LIST=12.0+PTX below.
VIBEVOICE_BASE_IMAGE=nvcr.io/nvidia/pytorch:25.09-py3

## Uncomment on GB10 (aarch64 Blackwell). Leave empty on x86.
TORCH_CUDA_ARCH_LIST=

## Models
VIBEVOICE_ASR_MODEL=microsoft/VibeVoice-ASR
VIBEVOICE_REALTIME_MODEL=microsoft/VibeVoice-Realtime-0.5B

## HuggingFace token (optional, recommended for rate limits)
HUGGING_FACE_HUB_TOKEN=

## Attention backend: sdpa | flash_attention_2 | eager
VIBEVOICE_ATTN=sdpa

## Gradio ASR generation ceiling
VIBEVOICE_MAX_NEW_TOKENS=8192

## Ports
VIBEVOICE_ASR_PORT=7860
VIBEVOICE_REALTIME_PORT=3000
VIBEVOICE_VLLM_PORT=8005
VIBEVOICE_OPENAI_TTS_PORT=8006

## vLLM experimental (profile=vllm)
VIBEVOICE_VLLM_IMAGE=vllm/vllm-openai:v0.14.1
VIBEVOICE_VLLM_MEM_UTIL=0.18
VIBEVOICE_VLLM_MAX_SEQS=16
VIBEVOICE_VLLM_MAX_MODEL_LEN=65536
VIBEVOICE_VLLM_API_KEY=
