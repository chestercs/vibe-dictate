# ============================================================================
#  .env template for the GB10 VibeVoice stack.
#  Copy next to the compose file:
#      cp .env.vibevoice-gb10.example .env
#  Then fill in at least VIBEVOICE_BASE_DIR and (optionally) the HF token.
# ============================================================================

## Stack identity (matches the Gemma compose pattern)
COMPOSE_PROJECT_NAME=vibevoice_asr_gb10
COMPOSE_FILE=docker-compose-vibevoice-asr-gb10.yml

## Host root for the named-bind volumes (USB mount on GB10, like Gemma).
## Create with: sudo mkdir -p $VIBEVOICE_BASE_DIR/data/{hf-cache,torch-cache,pip-cache,openai-tts}
VIBEVOICE_BASE_DIR=/media/usb/vibevoice

## Path to the upstream VibeVoice checkout (host side). Default assumes
## you cloned it as `VibeVoice/` inside the vibe-dictate repo. Override
## to an absolute path if you keep it elsewhere.
VIBEVOICE_SRC=./VibeVoice

## Base image (A-opció — runtime install, NVIDIA prebuilt aarch64 CUDA 13).
## For B-opció, use Dockerfile.vibevoice-gb10 and swap the compose
## `image:` line for a `build:` block.
VIBEVOICE_BASE_IMAGE=nvcr.io/nvidia/pytorch:25.12-py3

## Models (HuggingFace repo id or local path)
VIBEVOICE_ASR_MODEL=microsoft/VibeVoice-ASR
VIBEVOICE_REALTIME_MODEL=microsoft/VibeVoice-Realtime-0.5B

## HuggingFace token (optional, recommended to avoid rate limits)
HUGGING_FACE_HUB_TOKEN=

## Attention backend: sdpa (fast on Blackwell) | flash_attention_2 | eager
VIBEVOICE_ATTN=sdpa

## ASR generation: 8192 tok ≈ 5 min audio (plenty for PTT bursts, smaller
## KV cache = faster peak inference). 16384 ≈ 10 min, 32768 ≈ 60 min.
VIBEVOICE_MAX_NEW_TOKENS=8192

## Port overrides (Gemma 4 runs on 8004, don't collide)
VIBEVOICE_ASR_PORT=7860
VIBEVOICE_REALTIME_PORT=3000
VIBEVOICE_VLLM_PORT=8005
VIBEVOICE_OPENAI_TTS_PORT=8006
VIBEVOICE_OPENAI_ASR_PORT=8080

## OpenAI-compat ASR (default — runs on plain `docker compose up -d`).
## Uses microsoft/VibeVoice-ASR-HF (transformers-native, 8B). Leave API key
## blank to disable bearer-token auth. Swap models by changing
## VIBEVOICE_OPENAI_ASR_MODEL and restarting the container — conflicts
## with the legacy Gradio demo (`--profile gradio`) for GPU budget.
VIBEVOICE_OPENAI_ASR_MODEL=microsoft/VibeVoice-ASR-HF
VIBEVOICE_OPENAI_ASR_API_KEY=

## Experimental vLLM profile (only active with --profile vllm)
VIBEVOICE_VLLM_IMAGE=vllm/vllm-openai:v0.14.1
VIBEVOICE_VLLM_MEM_UTIL=0.18
VIBEVOICE_VLLM_MAX_SEQS=16
VIBEVOICE_VLLM_MAX_MODEL_LEN=65536
VIBEVOICE_API_KEY=
