# ============================================================================
#  .env template for the GB10 VibeVoice STT backend (DGX Spark, aarch64).
#  Copy: cp .env.vibevoice-gb10.example .env
#  Then fill in at least VIBEVOICE_BASE_DIR and (optionally) the HF token.
#
#  This stack only runs the OpenAI-compat ASR shim
#  (/v1/audio/transcriptions) — see vibevoice-lab/ for the Gradio demo,
#  realtime TTS, vLLM experiments and the B-opció prebuilt image.
# ============================================================================

## Stack identity (matches the Gemma compose pattern)
COMPOSE_PROJECT_NAME=vibevoice_asr_gb10
COMPOSE_FILE=docker-compose-vibevoice-asr-gb10.yml

## Host root for the named-bind volumes (USB mount on GB10, like Gemma).
## Create with: sudo mkdir -p $VIBEVOICE_BASE_DIR/data/{hf-cache,torch-cache,pip-cache}
VIBEVOICE_BASE_DIR=/media/usb/vibevoice

## Base image (NVIDIA prebuilt aarch64 CUDA 13).
VIBEVOICE_BASE_IMAGE=nvcr.io/nvidia/pytorch:25.12-py3

## HuggingFace token (optional, recommended to avoid rate limits)
HUGGING_FACE_HUB_TOKEN=

## ASR generation: 8192 tok ≈ 5 min audio (plenty for PTT bursts, smaller
## KV cache = faster peak inference). 16384 ≈ 10 min, 32768 ≈ 60 min.
VIBEVOICE_MAX_NEW_TOKENS=8192

## OpenAI-compat ASR. Uses microsoft/VibeVoice-ASR-HF (transformers-native,
## 8B). The default API key matches the client's baked-in default
## (src/config.rs::DEFAULT_API_KEY) so a fresh install is authenticated
## out of the box — rotate it here + in the tray menu (STT server → API
## key) before exposing the backend publicly. Leave blank to disable
## bearer-token auth entirely. Gemma 4 runs on 8004 by convention —
## don't collide.
VIBEVOICE_OPENAI_ASR_MODEL=microsoft/VibeVoice-ASR-HF
VIBEVOICE_OPENAI_ASR_API_KEY=vibe-dictate-default-change-me
VIBEVOICE_OPENAI_ASR_PORT=8080
