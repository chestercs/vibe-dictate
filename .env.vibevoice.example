# ============================================================================
#  .env template for the x86_64 VibeVoice STT backend (NVIDIA consumer GPUs).
#  Copy: cp .env.vibevoice.example .env
#
#  This stack only runs the OpenAI-compat ASR shim
#  (/v1/audio/transcriptions) — see vibevoice-lab/ for the Gradio demo,
#  realtime TTS, vLLM experiments and the B-opció prebuilt image.
# ============================================================================

## Stack identity
COMPOSE_PROJECT_NAME=vibevoice
COMPOSE_FILE=docker-compose-vibevoice.yml

## Base image. NVIDIA's PyTorch 25.09 (CUDA 12.x, amd64) is a safe
## default for RTX-class GPUs. Override for cu13 / aarch64 if needed.
VIBEVOICE_BASE_IMAGE=nvcr.io/nvidia/pytorch:25.09-py3

## HuggingFace token (optional, recommended for rate limits)
HUGGING_FACE_HUB_TOKEN=

## ASR generation ceiling. 8192 tok ≈ 5 min audio. 16384 ≈ 10 min,
## 32768 ≈ 60 min. Smaller = faster peak inference and smaller KV cache.
VIBEVOICE_MAX_NEW_TOKENS=8192

## OpenAI-compat ASR. Uses microsoft/VibeVoice-ASR-HF (transformers-native,
## 8B). Leave API key blank to disable bearer-token auth.
VIBEVOICE_OPENAI_ASR_MODEL=microsoft/VibeVoice-ASR-HF
VIBEVOICE_OPENAI_ASR_API_KEY=
VIBEVOICE_OPENAI_ASR_PORT=8080
