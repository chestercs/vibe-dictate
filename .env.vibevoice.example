# ============================================================================
#  .env template for the x86_64 VibeVoice stack (NVIDIA consumer GPUs).
#  Copy: cp .env.vibevoice.example .env
# ============================================================================

## Stack identity
COMPOSE_PROJECT_NAME=vibevoice
COMPOSE_FILE=docker-compose-vibevoice.yml

## Path to the upstream VibeVoice checkout. Default: `VibeVoice/`
## subfolder inside the vibe-dictate repo (the structure produced by
## cloning VibeVoice there after cloning vibe-dictate).
## Override to an absolute path if you keep it elsewhere.
VIBEVOICE_SRC=./VibeVoice

## Base image. NVIDIA's PyTorch 25.09 (CUDA 12.x, amd64) is a safe
## default for RTX-class GPUs. Override for cu13 / aarch64 if needed.
VIBEVOICE_BASE_IMAGE=nvcr.io/nvidia/pytorch:25.09-py3

## Models
VIBEVOICE_ASR_MODEL=microsoft/VibeVoice-ASR
VIBEVOICE_REALTIME_MODEL=microsoft/VibeVoice-Realtime-0.5B

## HuggingFace token (optional, recommended for rate limits)
HUGGING_FACE_HUB_TOKEN=

## Attention backend
VIBEVOICE_ATTN=sdpa

## ASR generation ceiling (see .env.vibevoice-gb10.example for sizing)
VIBEVOICE_MAX_NEW_TOKENS=8192

## Ports
VIBEVOICE_ASR_PORT=7860
VIBEVOICE_REALTIME_PORT=3001
